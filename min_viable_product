import bpy


def set_material_to_obj(item, material_name, action):
  
    match action:
        
        #add    
        case 1:  
            mat = bpy.data.materials[material_name] #already exists
           
            #look the material slot up in the material collection for obj
            if material_name in item.data.materials:
                pass
            else:    
                item.data.materials.append(mat) #add the material to obj
        
        # delete
        case 2:
            
            #make a shallow copy of the material list. Exclude unwanted slots and their copies
                  
            item.data.materials[:] = [ m for m in item.data.materials if m.name != material_name]
            
        #flush    
        case 3:   
            item.data.materials.clear()
             
        case _:
            pass
    
  
def select_option():
    
    for every in bpy.context.selected_objects:
        
        if every.type == 'MESH':
            
            new_mats = ["X","Fizz"]
        
            for m in new_mats:
                set_material_to_obj(every, m, 1)
        
        
select_option()
